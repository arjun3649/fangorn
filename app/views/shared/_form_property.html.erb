<%# app/views/properties/_form.html.erb %>
<div class="p-6 bg-white rounded-lg shadow-md max-w-md mx-auto mt-5">
    <h2 class="text-2xl font-bold mb-4">Property Form</h2>

    <%= form_with(model: [@product, property],class: "space-y-4") do |f| %>
    <% if property.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 text-red-500 rounded-md">
        <h3 class="font-bold"><%= pluralize(property.errors.count, "error") %> prohibited this property from being saved:</h3>
        <ul class="list-disc list-inside">
            <% property.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
            <% end %>
        </ul>
    </div>
    <% end %>

    <div class="mt-1">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, 
            autocomplete: "off",
            data: { 
              search: true,
              product_id: @product.id  # Add product ID here
            },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border",
            placeholder: "e.g., Weight, Size, Color" %>
        <div id="search-results" class="mt-2 hidden"></div>
    </div>

    <%# Keep other fields as they are but add IDs %>
    <%= f.text_area :description,
     id: 'property_description', 
     class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border",
    placeholder: "Description of the property" %>
    <%= f.text_field :unit,
     id: 'property_unit', 
     class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border",
      placeholder: "e.g., 500gms,5000mah" %>


    <div class="mt-6">
        <%= f.submit class: "w-full py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
</div>
<% end %>
</div>