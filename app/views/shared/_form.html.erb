<%# app/views/products/_form.html.erb %>
<div class="p-6 bg-white rounded-lg shadow-md max-w-md mx-auto mt-5">
    <h2 class="text-2xl font-bold mb-4">Product Form</h2>

    <%= form_with(model: product, local: true, class: "space-y-4") do |f| %>
    <% if product.errors.any? %>
    <div class="mb-4 p-4 bg-red-50 text-red-500 rounded-md">
        <h3 class="font-bold"><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h3>
        <ul class="list-disc list-inside">
            <% product.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
            <% end %>
        </ul>
    </div>
    <% end %>

    <div class="mt-1">
        <%= f.label :primary_category, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :primary_category, 
          options_for_select([
            ['Select a primary category', ''],
            ['Electronics', 'electronics'],
            ['Clothing', 'clothing'],
            ['Home & Garden', 'home_garden'],
            ['Food & Beverage', 'food'],
            ['Books & Education', 'books'],
            ['Technology', 'technology'],
            ['Art & Crafts', 'art_crafts']
          ], selected: product.primary_category),
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" %>
    </div>

    <div class="mt-1">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" %>
    </div>



    <div class="mt-1">
        <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" %>
    </div>

    <div class="mt-4">
        <%= f.submit class: "w-full py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    </div>
    <% end %>
</div>