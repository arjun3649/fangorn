<%== form_for @product do |f| %>
<div class="p-6 bg-white rounded-lg shadow-md max-w-md mx-auto mt-5">
    <h2 class="text-2xl font-bold mb-4">Product Form</h2>

    <form class="space-y-4" *ngForm="productForm">
        <!-- Primary Category Dropdown -->
        <div class="mt-1">
            <label for="primary_category" class="block text-sm font-medium text-gray-700">Primary Category</label>
            <select id="primary_category" name="primary_category" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border">
                <!-- Add your categories here -->
                <option value="">Select a primary category</option>
                <option value="electronics">Electronics</option>
                <option value="clothing">Clothing</option>
                <option value="home_garden">Home & Garden</option>
                <option value="food">Food & Beverage</option>
                <option value="books">Books & Education</option>
                <option value="technology">Technology</option>
                <option value="art_crafts">Art & Crafts</option>
                <!-- You can add more categories as needed -->
            </select>
        </div>

        <!-- Name Input -->
        <div class="mt-1">
            <label for="name" class="block text-sm font-medium text-gray-700">Product Name</label>
            <input id="name" name="name" type="text" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" required>
        </div>



        <div class="mt-1">
            <label for="price" class="block text-sm font-medium text-gray-700">Price</label>
            <input id="price" name="price" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" required>
        </div>


        <!-- Description Input -->
        <div class="mt-1">
            <label for="description" class="block text-sm font-medium text-gray-700">Description</label>
            <textarea id="description" name="description" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border" required></textarea>
        </div>

        <!-- Submit Button -->
        <div class="mt-4">
            <button type="submit" class="w-full py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                Save Product
            </button>
        </div>
    </form>
</div>

<% end  %>