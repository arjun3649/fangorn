<div class="container mx-auto px-4 py-6 max-w-4xl">
    <h2 class="text-xl font-bold mb-4 text-gray-800">Add Property to <%= @product.name %></h2>

    <div class="bg-white p-6 rounded-lg shadow-md">
        <!-- Search Section -->
        <%= form_tag(new_product_product_property_path(@product), method: :get, class: "mb-4") do %>
        <div class="flex gap-2">
            <%= text_field_tag :search, params[:search], 
              placeholder: "Search existing properties...",
              class: "flex-grow px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
            <%= submit_tag "Search", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition duration-150 ease-in-out" %>
        </div>
        <% end %>

        <!-- Search Results -->
        <% if @matching_properties && @matching_properties.any? %>
        <div class="mb-4 bg-gray-50 p-3 rounded-md">
            <div class="space-y-2">
                <% @matching_properties.each do |property| %>
                <div class="p-2 border border-gray-200 rounded-md hover:bg-gray-50 transition duration-150">
                    <div class="flex items-center justify-between">
                        <div class="flex-1">
                            <p class="font-medium text-gray-800"><%= property.name %></p>
                            <div class="flex gap-2 text-sm text-gray-600">
                                <span class="bg-blue-100 px-2 py-0.5 rounded-full"><%= property.unit %></span>
                                <span class="truncate"><%= property.description %></span>
                            </div>
                        </div>
                        <button type="button" onclick="selectProperty(<%= property.id %>, '<%=  property.name %>', '<%=  property.unit %>', '<%=  property.description %>')" class="px-3 py-1 text-sm bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300 transition">
                            Select
                        </button>
                    </div>
                </div>
                <% end %>
            </div>
        </div>
        <% elsif @matching_properties && @matching_properties.empty? %>
        <div class="bg-yellow-50 p-3 rounded-md mb-4 text-sm text-yellow-800">
            <p>No matching properties found. Create new property with "<%= params[:search] %>":</p>
        </div>
        <% end %>

        <!-- Main Form -->
        <%= form_tag(product_product_properties_path(@product), method: :post) do %>
        <!-- Hidden field for selected property ID -->
        <%= hidden_field_tag :property_id, nil, id: "selected_property_id" %>

        <div class="space-y-4">
            <!-- Property Fields -->
            <div id="property_section" class="bg-gray-50 p-4 rounded-md">
                <p class="text-sm font-medium text-gray-500 mb-3" id="property_section_title">Create New Property</p>

                <div id="property_fields" class="space-y-3">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <%= label_tag :property_name, "Property Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
                            <%= text_field_tag :property_name, params[:search], class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", id: "property_name_field", required: true %>
                        </div>
                        <div>
                            <%= label_tag :property_unit, "Unit", class: "block text-sm font-medium text-gray-700 mb-1" %>
                            <%= text_field_tag :property_unit, nil, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", id: "property_unit_field", required: true %>
                        </div>
                    </div>

                    <div>
                        <%= label_tag :property_description, "Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
                        <%= text_area_tag :property_description, nil, rows: 2, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", id: "property_description_field", required: true %>
                    </div>
                </div>
            </div>

            <!-- Value and Remarks -->
            <div class="bg-gray-50 p-4 rounded-md">


                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <%= label_tag :value, "Value", class: "block text-sm font-medium text-gray-700 mb-1" %>
                        <%= text_field_tag :value, nil, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
                    </div>
                    <div>
                        <%= label_tag :remarks, "Remarks", class: "block text-sm font-medium text-gray-700 mb-1" %>
                        <%= text_field_tag :remarks, nil, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <%= submit_tag "Save Property", class: "w-full px-4 py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition duration-150 ease-in-out" %>
            </div>
        </div>
        <% end %>

        <% if @errors.present? %>
        <div class="mt-4 p-3 bg-red-50 rounded-md text-red-600 text-sm">
            <p class="font-medium">Please fix the following errors:</p>
            <ul class="list-disc pl-5 mt-1">
                <% @errors.each do |error| %>
                <li><%= error %></li>
                <% end %>
            </ul>
        </div>
        <% end %>
    </div>
</div>

<script>
    function selectProperty(id, name, unit, description) {
        // Set the hidden property_id field
        document.getElementById('selected_property_id').value = id;

        // Populate the property fields with the selected property data
        document.getElementById('property_name_field').value = name;
        document.getElementById('property_unit_field').value = unit;
        document.getElementById('property_description_field').value = description;

        // Disable the fields since we're using an existing property
        document.getElementById('property_name_field').setAttribute('readonly', true);
        document.getElementById('property_unit_field').setAttribute('readonly', true);
        document.getElementById('property_description_field').setAttribute('readonly', true);

        // Add visual indicator that this is a selected property
        document.getElementById('property_fields').classList.add('bg-blue-100', 'border', 'border-blue-200');

        // Update the section title
        document.getElementById('property_section_title').textContent = 'Selected Existing Property';
        document.getElementById('property_section_title').classList.add('text-blue-600');


    }
</script>