<div class="container mx-auto py-8">
    <div class="flex flex-col gap-8">

        <%# Image section %>
        <div class="w-full">
            <img src="https://images.panda.org/assets/images/pages/welcome/orangutan_1600x1000_279157.jpg" alt="<%= @product.name %>" class="w-full object-cover" />
        </div>

        <%# Product details section %>
        <div class="w-full">
            <h1 class="text-4xl font-bold mb-4"><%= @product.name %></h1>

            <div class="space-y-6">
                <div>
                    <p class="text-gray-700 text-lg"><%= @product.description %></p>
                </div>

                <div>
                    <p class="text-sm text-gray-600">Created by: <%= @product.created_by %></p>
                </div>

                <%# Variants section %>
                <div class="mt-8">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-semibold">Variants</h2>
                        <%= link_to "Add Variant", new_product_variant_path(@product), class: "text-blue-600" %>
                    </div>

                    <% if @product.variant.present? %>
                    <% @product.variant.each do |variant| %>
                    <div class="border p-4 rounded-lg mb-4">
                        <div class="flex justify-between">
                            <h3 class="font-medium"><%= variant.name %></h3>
                            <div class="flex gap-2">
                                <%= link_to "Edit", edit_product_variant_path(@product, variant), class: "text-blue-600" %>
                                <%= button_to "Delete", product_variant_path(@product, variant), method: :delete, class: "text-red-600", data: { confirm: "Are you sure?" } %>
                            </div>
                        </div>
                    </div>
                    <% end %>
                    <% else %>
                    <p class="text-gray-500 italic">No variants available yet</p>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>