<div class="container mx-auto py-8 px-4">
    <div class="flex flex-col gap-10">

        <%# Image Section %>
        <div class="w-full">
            <img src="https://images.panda.org/assets/images/pages/welcome/orangutan_1600x1000_279157.jpg" alt="<%= @product.name %>" class="w-full h-80 object-cover rounded-lg shadow-md" />
        </div>

        <%# Product Details Section %>
        <div class="w-full">
            <h1 class="text-4xl font-bold mb-4 text-gray-900"><%= @product.name %></h1>

            <div class="space-y-6">
                <div>
                    <p class="text-gray-700 text-lg"><%= @product.description %></p>
                </div>

                <div>
                    <p class="text-sm text-gray-600">Created by: <%= @product.created_by %></p>
                </div>

                <%# Variants Section %>
                <div class="mt-8">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-semibold text-gray-800">Variants</h2>
                        <%= link_to "Add Variant", new_product_variant_path(@product), 
                            class: "px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition" %>
                    </div>

                    <% active_variants = @product.variant.where(deleted_at: nil) %>
                    <% if active_variants.exists? %>
                    <% active_variants.each do |variant| %>
                    <div class="border p-4 rounded-lg mb-4 shadow-sm">
                        <div class="flex justify-between items-center">
                            <h3 class="font-medium text-gray-800"><%= variant.name %></h3>
                            <div class="flex gap-2">
                                <%= link_to "Edit", edit_product_variant_path(@product, variant), 
                                            class: "px-4 py-2 bg-blue-400 hover:bg-blue-600 text-white rounded-lg transition" %>

                                <%= button_to product_variant_path(@product, variant),
                                            method: :delete,
                                            class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition",
                                            data: { turbo_confirm: "Are you sure you want to delete this variant?" } do %>
                                Delete
                                <% end %>
                            </div>
                        </div>
                    </div>
                    <% end %>
                    <% else %>
                    <p class="text-gray-500 italic">No variants available yet.</p>
                    <% end %>
                </div>

                <%# Property Section %>
                <div class="mt-10 p-6 bg-gray-100 rounded-lg shadow">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-2xl font-semibold text-gray-800">Product Properties</h2>
                        <%= link_to "Add Property", new_product_property_path(@product), 
                            class: "px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition" %>
                    </div>

                    <%# Property Search %>
                    <div class="mb-6">
                        <%= form_with(url: product_path(@product), method: :get, class: "flex gap-2") do |f| %>
                        <%= f.text_field :search, 
            value: params[:search],
            class: "flex-grow rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 border",
            placeholder: "Search Properties  e.g., Weight, Size, Color",
            data: { search_input: true } %>

                        <%= f.submit "Search", 
            class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
                        <% end %>

                        <div id="search-results" class="mt-2 hidden absolute z-10 bg-white w-full rounded-md shadow-lg"></div>
                    </div>

                    <% filtered_properties = params[:search].present? ? @product.property.where('name LIKE ?', "%#{params[:search]}%") : nil %>

                    <% if filtered_properties.present? %>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unit</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% filtered_properties.each do |property| %>
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= property.name %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= property.description %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= property.unit %></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <div class="flex gap-2">
                                            <%= link_to "Edit", edit_product_property_path(@product, property), 
                    class: "text-blue-600 hover:text-blue-900" %>
                                            <%= button_to "Delete", product_property_path(@product, property),
                    method: :delete,
                    class: "text-red-600 hover:text-red-900 bg-transparent border-none cursor-pointer",
                    data: { turbo_confirm: "Are you sure you want to delete this property?" } %>
                                        </div>
                                    </td>
                                </tr>
                                <% end %>
                            </tbody>
                        </table>
                    </div>
                    <% else %>
                    <% if params[:search].present? %>
                    <p class="text-gray-500 italic">No properties found matching your search.</p>
                    <% else %>
                    <p class="text-gray-500 italic">Use the search above to find properties.</p>
                    <% end %>
                    <% end %>
                </div>
                <%= render "/shared/show_properties" %>

            </div>
        </div>
    </div>
</div>