<div class="max-w-4xl mx-auto px-4 py-8">
    <%# Flash Messages Section %>
    <% if flash.any? %>
    <div class="mb-6">
        <% flash.each do |type, message| %>
        <div class="<%= type == 'notice' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %> p-4 rounded-lg mb-4">
            <%= message %>
        </div>
        <% end %>
    </div>
    <% end %>

    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 m-5">
            <% if @products.present? %>
            <% @products.each do |product| %>
            <%= turbo_frame_tag product do %>
            <div class="group relative rounded-lg overflow-hidden transition-transform duration hover:scale-105">
                <img src="https://images.panda.org/assets/images/pages/welcome/orangutan_1600x1000_279157.jpg" alt="<%= product.name %>" class="w-full h-48 object-cover group-hover:scale-110" />

                <div class="p-4 relative z-10 bg-gradient-to-t from-transparent to-white rounded-lg shadow-md">
                    <h2 class="text-xl font-semibold text-gray-800 mb-2 line-clamp-3">
                        <%= product.name %>
                    </h2>



                    <div>
                        <p class="mt-2 text-sm text-gray-600 line-clamp-3">
                            <%= product.description %>
                        </p>
                        <p class="mt-2 text-sm text-gray-600 line-clamp-3">
                            Createdby: <%= product.created_by %>
                        </p>

                        <%= button_to product_path(product),
                    method: :delete,
                    class: "mt-4 inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors duration-200",
                    data: { turbo_confirm: "Are you sure you want to delete this product?" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Delete
                        <% end %>
                    </div>

                    <%= link_to "Edit",
                  edit_product_path(product),
                  class: "mt-2 inline-block text-blue-600 hover:text-blue-800",
                  data: { turbo_frame: dom_id(product) }
                %>
                    <%= link_to "Add Variant",
                  
                  class: "mt-2 inline-block text-blue-600 hover:text-blue-800",
                  data: { turbo_frame: dom_id(product) }
                %>

                </div>
            </div>
            <% end %>
            <% end %>
            <% else %>
            <div class="col-span-full text-center py-12">
                <h1 class="text-2xl font-bold text-gray-800 mb-4">No Products Found</h1>
                <p class="text-gray-600">Sorry, we couldn't find any products that match your criteria.</p>
                <%= link_to "Add New Product", new_product_path, 
              class: "mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200" %>
            </div>
            <% end %>
        </div>
    </div>
</div>