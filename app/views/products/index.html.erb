<%# products/index.html.erb %>
<div class="container mx-auto px-4 py-8">
    <%# Flash Messages Section %>
    <%# Flash Messages Section %>
    <% if flash.any? %>
    <div class="mb-4">
        <% flash.each do |type, message| %>
        <div class="p-4 rounded-lg bg-blue-100 text-blue-700 border border-blue-200">
            <%= message %>
        </div>
        <% end %>
    </div>
    <% end %>

    <%# Products List Section %>
    <div class="products-grid grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% if @products.present? %>
        <% @products.each do |product| %>
        <%= turbo_frame_tag product do %>
        <%= link_to product_path(product),data:{turbo:false}, class: "block group relative rounded-lg overflow-hidden bg-white shadow-md hover:shadow-lg transition-all duration-300" do %>
        <div class="aspect-w-16 aspect-h-9 mb-4">
            <img src="https://images.panda.org/assets/images/pages/welcome/orangutan_1600x1000_279157.jpg" alt="<%= product.name %>" class="w-full h-48 object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>

        <div class="p-4">
            <h3 class="text-xl font-semibold mb-2"><%= product.name %></h3>

            <p class="text-gray-600 mb-4"><%= product.description %></p>

            <div class="text-sm text-gray-500">
                Created by: <%= product.created_by %>
            </div>

            <div class="mt-4 flex space-x-4">
                <%= button_to product_path(product),
                    method: :delete,
                    class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors duration-200",
                    data: { turbo_confirm: "Are you sure you want to delete this product?" } do %>
                Delete
                <% end %>

                <%= link_to "Edit",
                    edit_product_path(product),
                    class: "inline-flex items-center px-4 py-2 text-blue-600 hover:text-blue-800 transition-colors duration-200",
                    data: { turbo_frame: dom_id(product) } %>
            </div>
        </div>
        <% end %>
        <% end %>
        <% end %>
        <% else %>
        <div class="col-span-full text-center py-8">
            <h3 class="text-xl font-semibold mb-2">No Products Found</h3>
            <p class="text-gray-600 mb-4">Sorry, we couldn't find any products that match your criteria.</p>
            <%= link_to "Add New Product", 
            new_product_path,
            class: "mt-4 inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200" %>
        </div>
        <% end %>
    </div>
</div>